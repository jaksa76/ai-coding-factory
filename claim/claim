#!/usr/bin/env bash
set -euo pipefail

# claim — claim an unassigned Jira issue by assigning it to self
#
# Usage:
#   claim --project <key> --account-id <id>
#
# Environment variables:
#   JIRA_SITE   — Jira host, e.g. mycompany.atlassian.net
#   JIRA_EMAIL  — Jira account email
#   JIRA_TOKEN  — Jira API token

usage() {
    echo "Usage: claim --project <key> --account-id <id> [--for-planning]"
    echo ""
    echo "Environment variables required:"
    echo "  JIRA_SITE   Jira host (e.g. mycompany.atlassian.net)"
    echo "  JIRA_EMAIL  Jira account email"
    echo "  JIRA_TOKEN  Jira API token"
    echo ""
    echo "Options:"
    echo "  --for-planning   Transition claimed issue to Planning status instead of In Progress."
    exit 1
}

error_exit() {
    echo "Error: $1" >&2
    exit 1
}

# Parse arguments
PROJECT=""
ACCOUNT_ID=""
FOR_PLANNING=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        --project)
            PROJECT="$2"
            shift 2
            ;;
        --account-id)
            ACCOUNT_ID="$2"
            shift 2
            ;;
        --for-planning)
            FOR_PLANNING=1
            shift 1
            ;;
        --help|-h)
            usage
            ;;
        *)
            error_exit "Unknown option: $1"
            ;;
    esac
done

[[ -z "$PROJECT" ]]    && error_exit "--project <key> is required"
[[ -z "$ACCOUNT_ID" ]] && error_exit "--account-id <id> is required"
[[ -z "${JIRA_SITE:-}" ]]  && error_exit "JIRA_SITE environment variable is not set"
[[ -z "${JIRA_EMAIL:-}" ]] && error_exit "JIRA_EMAIL environment variable is not set"
[[ -z "${JIRA_TOKEN:-}" ]] && error_exit "JIRA_TOKEN environment variable is not set"

# Authenticate with Jira if not already logged in
if ! acli jira auth status 2>/dev/null | grep -q "Authenticated"; then
    echo "$JIRA_TOKEN" | acli jira auth login \
        --site "$JIRA_SITE" \
        --email "$JIRA_EMAIL" \
        --token
fi

# Attempt to claim an issue (optimistic locking loop)
while true; do
    echo "Searching for unassigned open issues in project $PROJECT..."

    # Find unassigned, non-done issues; take the first one
    # Exclude issues that require planning unless --for-planning is set
    if [[ "$FOR_PLANNING" -eq 0 ]]; then
        if [[ "${PLAN_BY_DEFAULT:-false}" == "true" ]]; then
            # Planning is opt-out: only pick up issues explicitly marked skip-plan
            PLANNING_FILTER=' AND labels IN ("skip-plan")'
        else
            # Planning is opt-in: skip issues explicitly marked needs-plan
            PLANNING_FILTER=' AND labels NOT IN ("needs-plan")'
        fi
    else
        PLANNING_FILTER=""
    fi
    SEARCH_JQL="project = \"$PROJECT\" AND assignee is EMPTY AND statusCategory != Done${PLANNING_FILTER} ORDER BY created ASC"
    echo "Running JQL: $SEARCH_JQL"
    SEARCH_OUTPUT=$(acli jira workitem search --jql "$SEARCH_JQL" --json --paginate 2>&1)
    echo "Search result: $SEARCH_OUTPUT"

    # Loop through issues to find one matching planning logic
    while :; do
        ISSUE_KEY=$(printf '%s\n' "$SEARCH_OUTPUT" \
            | jq -r 'if type == "array" then .[0].key // empty else empty end' 2>/dev/null || true)
        if [[ -z "$ISSUE_KEY" ]]; then
            if [[ "$FOR_PLANNING" -eq 1 ]]; then
                echo "No unassigned open issues requiring planning found in project $PROJECT."
            else
                echo "No unassigned open issues found in project $PROJECT."
            fi
            exit 2
        fi
        # Fetch labels for this issue
        ISSUE_LABELS=$(printf '%s\n' "$SEARCH_OUTPUT" | jq -r 'if type == "array" and .[0] then .[0].fields.labels // [] | @sh else "" end' 2>/dev/null || true)
        PLAN_BY_DEFAULT=${PLAN_BY_DEFAULT:-false}
        NEEDS_PLAN=false
        SKIP_PLAN=false
        # shellcheck disable=SC2086
        for label in $ISSUE_LABELS; do
            case $label in
                "needs-plan"|needs-plan) NEEDS_PLAN=true ;;
                "skip-plan"|skip-plan) SKIP_PLAN=true ;;
            esac
        done
        # Decision matrix for planning requirement
        REQUIRE_PLAN=false
        if [[ "$SKIP_PLAN" == true ]]; then
            REQUIRE_PLAN=false
        elif [[ "$NEEDS_PLAN" == true ]]; then
            REQUIRE_PLAN=true
        elif [[ "$PLAN_BY_DEFAULT" == true ]]; then
            REQUIRE_PLAN=true
        fi
        # Only claim if planning is required when --for-planning is set
        if [[ "$FOR_PLANNING" -eq 1 && "$REQUIRE_PLAN" != true ]]; then
            echo "Skipping $ISSUE_KEY: planning not required by PLAN_BY_DEFAULT/labels."
            # Remove this issue from SEARCH_OUTPUT and try next
            SEARCH_OUTPUT=$(printf '%s\n' "$SEARCH_OUTPUT" | jq 'del(.[0])')
            continue
        fi
        if [[ "$FOR_PLANNING" -eq 0 && "$REQUIRE_PLAN" == true ]]; then
            echo "Skipping $ISSUE_KEY: planning required but --for-planning not set."
            SEARCH_OUTPUT=$(printf '%s\n' "$SEARCH_OUTPUT" | jq 'del(.[0])')
            continue
        fi
        break
    done

    echo "Attempting to claim $ISSUE_KEY..."

    # Assign to self
    acli jira workitem assign --key "$ISSUE_KEY" --assignee "$ACCOUNT_ID" --yes

    # Wait 10 seconds for Jira to settle (optimistic locking check)
    echo "Waiting 10s to verify assignment..."
    sleep 10

    # Re-fetch and verify assignee
    VERIFY_OUTPUT=$(acli jira workitem view "$ISSUE_KEY" --json 2>&1)
    echo "Verify output: $VERIFY_OUTPUT"
    ASSIGNEE=$(printf '%s\n' "$VERIFY_OUTPUT" | jq -r '.fields.assignee.accountId // empty' 2>/dev/null || true)
    echo "Assigned to: ${ASSIGNEE:-<nobody>}"

    if [[ "$ASSIGNEE" != "$ACCOUNT_ID" ]]; then
        echo "Assignment race detected on $ISSUE_KEY (assignee is now ${ASSIGNEE:-unassigned}). Retrying..."
        continue
    fi

    echo "Successfully claimed $ISSUE_KEY."

    # Transition to "In Progress" or "Planning" if --for-planning is set
    if [[ "$FOR_PLANNING" -eq 1 ]]; then
        TARGET_STATUS="Planning"
        # Verify the Planning status exists in the workflow before attempting transition
        echo "Verifying Planning status exists in project workflow..."
        TRANSITIONS_JSON=$(acli jira workitem transitions --key "$ISSUE_KEY" --json 2>&1)
        PLANNING_AVAILABLE=$(printf '%s\n' "$TRANSITIONS_JSON" \
            | jq -r '[.[].name] | map(select(. == "Planning")) | length' 2>/dev/null || echo "0")
        if [[ "$PLANNING_AVAILABLE" -eq 0 ]]; then
            error_exit "Planning status does not exist in the Jira workflow for project $PROJECT. Cannot use --for-planning."
        fi
    else
        TARGET_STATUS="In Progress"
    fi
    echo "Transitioning $ISSUE_KEY to $TARGET_STATUS..."
    TRANSITION_STATUS=0
    TRANSITION_OUTPUT=$(acli jira workitem transition --key "$ISSUE_KEY" --status "$TARGET_STATUS" --yes 2>&1) || TRANSITION_STATUS=$?
    echo "Transition output: $TRANSITION_OUTPUT"
    if [[ $TRANSITION_STATUS -ne 0 ]]; then
        echo "Warning: could not transition $ISSUE_KEY to $TARGET_STATUS (transition may not be available)"
    fi

    # Print issue details
    acli jira workitem view "$ISSUE_KEY" --json \
        | jq '{key: .key, summary: .fields.summary, description: (.fields.description // ""), status: .fields.status.name}'

    break
done
