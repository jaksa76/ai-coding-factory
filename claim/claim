#!/usr/bin/env bash
set -euo pipefail

# claim — claim an unassigned Jira issue by assigning it to self
#
# Usage:
#   claim --project <key> --account-id <id>
#
# Environment variables:
#   JIRA_SITE   — Jira host, e.g. mycompany.atlassian.net
#   JIRA_EMAIL  — Jira account email
#   JIRA_TOKEN  — Jira API token

usage() {
    echo "Usage: claim --project <key> --account-id <id> [--for-planning]"
    echo ""
    echo "Environment variables required:"
    echo "  JIRA_SITE   Jira host (e.g. mycompany.atlassian.net)"
    echo "  JIRA_EMAIL  Jira account email"
    echo "  JIRA_TOKEN  Jira API token"
    echo ""
    echo "Options:"
    echo "  --for-planning   Transition claimed issue to Planning status instead of In Progress."
    exit 1
}

error_exit() {
    echo "Error: $1" >&2
    exit 1
}

authenticate_jira() {
    if ! acli jira auth status 2>/dev/null | grep -q "Authenticated"; then
        echo "$JIRA_TOKEN" | acli jira auth login \
            --site "$JIRA_SITE" \
            --email "$JIRA_EMAIL" \
            --token
    fi
}

build_search_jql_for_planning() {
    local project="$1"

    if [[ "${PLAN_BY_DEFAULT:-false}" == "true" ]]; then
        # If planning is enabled, include all issues in To Do that aren't explicitly marked as skip-plan.
        echo "project = \"$project\" AND assignee is EMPTY AND status = \"To Do\" AND (labels NOT IN (\"skip-plan\") OR labels is EMPTY)"
    else
        # If planning is disabled, include only issues explicitly marked as needs-plan.
        echo "project = \"$project\" AND assignee is EMPTY AND status = \"To Do\" AND labels IN (\"needs-plan\")"
    fi
}

build_search_jql_for_implementation() {
    local project="$1"

    if [[ "${PLAN_BY_DEFAULT:-false}" == "true" ]]; then
        # If planning is enabled, include all issues in Plan Approved and issues in To Do that are marked as skip-plan (i.e. don't require planning).
        echo "project = \"$project\" AND assignee is EMPTY AND (status = \"Plan Approved\" OR (status = \"To Do\" AND labels IN (\"skip-plan\")))"
    else
        # If planning is disabled, include all issues in To Do that aren't explicitly marked as needs-plan (i.e. do require planning).
        echo "project = \"$project\" AND assignee is EMPTY AND status = \"To Do\" AND (labels NOT IN (\"needs-plan\") OR labels is EMPTY)"
    fi
}

# Outputs the JQL query to use for searching unassigned issues.
build_search_jql() {
    local project="$1"
    local for_planning="$2"

    if [[ "$for_planning" -eq 1 ]]; then
        build_search_jql_for_planning "$project"
    else
        build_search_jql_for_implementation "$project"
    fi
}

# Assigns an issue to the given account, waits to verify, and outputs the resulting assignee account ID.
assign_and_verify() {
    local issue_key="$1"
    local account_id="$2"

    acli jira workitem assign --key "$issue_key" --assignee "$account_id" --yes >&2
    echo "Waiting 10s to verify assignment..." >&2
    sleep 10

    acli jira workitem view "$issue_key" --json 2>&1 \
        | jq -r '.fields.assignee.accountId // empty' 2>/dev/null || true
}

# Transitions a claimed issue to Planning (if --for-planning) or In Progress.
transition_issue() {
    local issue_key="$1"
    local for_planning="$2"
    local transition_status=0
    local transition_output

    if [[ "$for_planning" -eq 1 ]]; then
        echo "Transitioning $issue_key to Planning..." >&2
        transition_output=$(acli jira workitem transition --key "$issue_key" --status "Planning" --yes 2>&1) || transition_status=$?
        echo "Transition output: $transition_output" >&2
        if [[ $transition_status -ne 0 ]]; then echo "Warning: could not transition $issue_key to Planning (transition may not be available)" >&2; fi
    else
        echo "Transitioning $issue_key to In Progress..." >&2
        transition_output=$(acli jira workitem transition --key "$issue_key" --status "In Progress" --yes 2>&1) || transition_status=$?
        echo "Transition output: $transition_output" >&2
        if [[ $transition_status -ne 0 ]]; then echo "Warning: could not transition $issue_key to In Progress (transition may not be available)" >&2; fi
    fi
}

# Parse arguments
PROJECT=""
ACCOUNT_ID=""
FOR_PLANNING=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        --project)
            PROJECT="$2"
            shift 2
            ;;
        --account-id)
            ACCOUNT_ID="$2"
            shift 2
            ;;
        --for-planning)
            FOR_PLANNING=1
            shift 1
            ;;
        --help|-h)
            usage
            ;;
        *)
            error_exit "Unknown option: $1"
            ;;
    esac
done

[[ -z "$PROJECT" ]]    && error_exit "--project <key> is required"
[[ -z "$ACCOUNT_ID" ]] && error_exit "--account-id <id> is required"
[[ -z "${JIRA_SITE:-}" ]]  && error_exit "JIRA_SITE environment variable is not set"
[[ -z "${JIRA_EMAIL:-}" ]] && error_exit "JIRA_EMAIL environment variable is not set"
[[ -z "${JIRA_TOKEN:-}" ]] && error_exit "JIRA_TOKEN environment variable is not set"

authenticate_jira

# Attempt to claim an issue (optimistic locking loop)
while true; do
    echo "Searching for unassigned open issues in project $PROJECT..." >&2

    # Find issues for claiming
    SEARCH_JQL=$(build_search_jql "$PROJECT" "$FOR_PLANNING")
    echo "Running JQL: $SEARCH_JQL" >&2
    SEARCH_OUTPUT=$(acli jira workitem search --jql "$SEARCH_JQL" --json --paginate 2>&1) || {
        echo "Error running search: $SEARCH_OUTPUT" >&2
        exit 1
    }

    if [[ -z "$SEARCH_OUTPUT" || "$SEARCH_OUTPUT" == "[]" ]]; then
        echo "No unassigned open issues found. Retrying in 30s..." >&2
        sleep 30
        continue
    fi

    ISSUE_KEY=$(printf '%s\n' "$SEARCH_OUTPUT" | jq -r '.[0].key // empty' 2>/dev/null || true)
    echo "Attempting to claim $ISSUE_KEY..." >&2

    ASSIGNEE=$(assign_and_verify "$ISSUE_KEY" "$ACCOUNT_ID")
    if [[ "$ASSIGNEE" != "$ACCOUNT_ID" ]]; then
        echo "Assignment race detected on $ISSUE_KEY (assignee is now ${ASSIGNEE:-unassigned}). Retrying..." >&2
        continue
    fi

    echo "Successfully claimed $ISSUE_KEY." >&2

    transition_issue "$ISSUE_KEY" "$FOR_PLANNING"

    # Print claimed issue key and summary
    acli jira workitem view "$ISSUE_KEY" --json | jq '{key: .key, summary: .fields.summary}'

    break
done
