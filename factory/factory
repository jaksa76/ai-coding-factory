#!/usr/bin/env bash
set -euo pipefail

# factory — manage AI coding worker containers
#
# Usage:
#   factory status                        # list running workers
#   factory add --image <img> --count <n> # start n workers
#   factory logs <worker-id>              # stream logs for a worker
#   factory stop <worker-id>              # stop a worker
#   factory stop --all                    # stop all workers

WORKER_LABEL="ai-coding-factory.worker=true"

usage() {
    echo "Usage: factory <command> [options]"
    echo ""
    echo "Commands:"
    echo "  status                        List running workers"
    echo "  add --image <img> --count <n> Start n workers with the given image"
    echo "  logs <worker-id>              Stream logs for a worker"
    echo "  stop <worker-id>              Stop a worker"
    echo "  stop --all                    Stop all workers"
    exit 1
}

error_exit() {
    echo "Error: $1" >&2
    exit 1
}

cmd_status() {
    docker ps --filter "label=$WORKER_LABEL" \
        --format "table {{.ID}}\t{{.Image}}\t{{.Status}}\t{{.Names}}"
}

cmd_add() {
    local image=""
    local count=""
    local extra_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image)
                [[ -z "${2:-}" ]] && error_exit "--image requires a value"
                image="$2"
                shift 2
                ;;
            --)
                shift
                extra_args=("$@")
                break
                ;;
            --*)
                error_exit "Unknown option: $1"
                ;;
            *)
                count="$1"
                shift
                ;;
        esac
    done

    [[ -z "$image" ]] && error_exit "--image is required"
    [[ -z "$count" ]] && error_exit "count is required"
    [[ ! "$count" =~ ^[0-9]+$ ]] && error_exit "count must be a positive integer"
    [[ "$count" -lt 1 ]] && error_exit "count must be at least 1"

    local ts
    ts="$(date +%s)"
    for ((i = 1; i <= count; i++)); do
        local name="factory-worker-${ts}-${i}"
        docker run -d \
            --restart=on-failure \
            --label "$WORKER_LABEL" \
            --name "$name" \
            "$image" \
            "${extra_args[@]+"${extra_args[@]}"}"
    done
}

cmd_logs() {
    local worker_id="${1:-}"
    [[ -z "$worker_id" ]] && error_exit "worker-id is required"
    docker logs -f "$worker_id"
}

cmd_stop() {
    local target="${1:-}"
    [[ -z "$target" ]] && error_exit "worker-id or --all is required"

    if [[ "$target" == "--all" ]]; then
        local ids
        ids="$(docker ps --filter "label=$WORKER_LABEL" --quiet)"
        if [[ -z "$ids" ]]; then
            echo "No running workers to stop."
            return 0
        fi
        # shellcheck disable=SC2086
        docker stop $ids
    else
        docker stop "$target"
    fi
}

[[ $# -eq 0 ]] && usage

case "$1" in
    status)
        shift
        cmd_status
        ;;
    add)
        shift
        cmd_add "$@"
        ;;
    logs)
        shift
        cmd_logs "$@"
        ;;
    stop)
        shift
        cmd_stop "$@"
        ;;
    --help|-h)
        usage
        ;;
    *)
        error_exit "Unknown command: $1"
        ;;
esac
