#!/usr/bin/env bash
set -euo pipefail

# factory — manage AI coding worker containers
#
# Usage:
#   factory status                        # list running workers
#   factory workers [count] [--env-file <file>]   # start implementation workers (default 1)
#   factory planners [count] [--env-file <file>]  # start planning workers (default 1)
#   factory add --image <img> <count> [--env-file <file>]  # start n workers
#   factory logs <worker-id>              # stream logs for a worker
#   factory stop <worker-id>              # stop a worker
#   factory stop --all                    # stop all workers
#   factory import-claude-credentials --env-file <file>
#
# Backend selection:
#   factory delegates container operations to the 'runtime' script in the same
#   directory. Create a symlink 'runtime' pointing to either:
#     runtime-docker  (local Docker; default)
#     runtime-aws     (AWS ECS Fargate)

RUNTIME="$(dirname "$0")/runtime"

usage() {
    echo "Usage: factory <command> [options]"
    echo ""
    echo "Commands:"
    echo "  status                        List running workers"
    echo "  workers [count] [--env-file f]   Start implementation workers (default: 1)"
    echo "  planners [count] [--env-file f]  Start planning workers (default: 1)"
    echo "  add --image <img> <count> [--env-file f]"
    echo "                                Start n workers with a specific image"
    echo "  logs <worker-id>              Stream logs for a worker"
    echo "  stop <worker-id>              Stop a worker"
    echo "  stop --all                    Stop all workers"
    echo "  import-claude-credentials --env-file <file>"
    echo "                                Import OAuth credentials from ~/.claude/.credentials.json"
    echo ""
    echo "Environment variables:"
    echo "  FACTORY_WORKER_IMAGE          Image used by 'workers' (default: worker-claude)"
    echo "  FACTORY_PLANNER_IMAGE         Image used by 'planners' (default: planner-claude)"
    echo "  FACTORY_ENV_FILE              Default env file passed to every worker container"
    echo ""
    echo "Backend (runtime symlink):"
    echo "  runtime -> runtime-docker     Local Docker (default)"
    echo "  runtime -> runtime-aws        AWS ECS Fargate"
    echo ""
    echo "AWS runtime environment variables (when runtime -> runtime-aws):"
    echo "  FACTORY_AWS_REGION            AWS region (default: us-east-1)"
    echo "  FACTORY_AWS_CLUSTER           ECS cluster name (default: ai-coding-factory)"
    echo "  FACTORY_AWS_SUBNET_ID         Subnet for ECS tasks"
    echo "  FACTORY_AWS_SECURITY_GROUP_ID Security group for ECS tasks"
    echo "  FACTORY_AWS_LOG_GROUP         CloudWatch log group (default: /ecs/ai-coding-factory)"
    exit 1
}

error_exit() {
    echo "Error: $1" >&2
    exit 1
}

_parse_count_and_env_file() {
    # Sets caller-scoped `count` and `env_file_args` array.
    count="1"
    env_file_args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --env-file)
                [[ -z "${2:-}" ]] && error_exit "--env-file requires a value"
                env_file_args=(--env-file "$2")
                shift 2
                ;;
            --*)
                error_exit "Unknown option: $1"
                ;;
            *)
                count="$1"
                shift
                ;;
        esac
    done
}

cmd_workers() {
    local count env_file_args
    _parse_count_and_env_file "$@"
    local image="${FACTORY_WORKER_IMAGE:-worker-claude}"
    local args=(--image "$image")
    [[ ${#env_file_args[@]} -gt 0 ]] && args+=("${env_file_args[@]}")
    args+=("$count")
    cmd_add "${args[@]}"
}

cmd_planners() {
    local count env_file_args
    _parse_count_and_env_file "$@"
    local image="${FACTORY_PLANNER_IMAGE:-planner-claude}"
    local args=(--image "$image")
    [[ ${#env_file_args[@]} -gt 0 ]] && args+=("${env_file_args[@]}")
    args+=("$count")
    cmd_add "${args[@]}"
}

cmd_status() {
    "$RUNTIME" status
}

cmd_add() {
    local image=""
    local count=""
    local env_file=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image)
                [[ -z "${2:-}" ]] && error_exit "--image requires a value"
                image="$2"
                shift 2
                ;;
            --env-file)
                [[ -z "${2:-}" ]] && error_exit "--env-file requires a value"
                env_file="$2"
                shift 2
                ;;
            --*)
                error_exit "Unknown option: $1"
                ;;
            *)
                count="$1"
                shift
                ;;
        esac
    done

    [[ -z "$image" ]] && error_exit "--image is required"
    [[ -z "$count" ]] && error_exit "count is required"
    [[ ! "$count" =~ ^[0-9]+$ ]] && error_exit "count must be a positive integer"
    [[ "$count" -lt 1 ]] && error_exit "count must be at least 1"

    env_file="${env_file:-${FACTORY_ENV_FILE:-}}"
    [[ -n "$env_file" && ! -f "$env_file" ]] && error_exit "env file not found: $env_file"

    local env_file_arg=()
    [[ -n "$env_file" ]] && env_file_arg=(--env-file "$env_file")

    local ts
    ts="$(date +%s)"
    for ((i = 1; i <= count; i++)); do
        local name="factory-worker-${ts}-${i}"
        local runtime_args=("$name" "$image")
        [[ ${#env_file_arg[@]} -gt 0 ]] && runtime_args+=("${env_file_arg[@]}")
        "$RUNTIME" add "${runtime_args[@]}"
    done
}

cmd_logs() {
    local worker_id="${1:-}"
    [[ -z "$worker_id" ]] && error_exit "worker-id is required"
    "$RUNTIME" logs "$worker_id"
}

cmd_import_claude_credentials() {
    local env_file=""
    local creds_file="${HOME}/.claude/.credentials.json"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --env-file)
                [[ -z "${2:-}" ]] && error_exit "--env-file requires a value"
                env_file="$2"
                shift 2
                ;;
            --*)
                error_exit "Unknown option: $1"
                ;;
            *)
                error_exit "Unexpected argument: $1"
                ;;
        esac
    done

    [[ -z "$env_file" ]] && error_exit "--env-file is required"
    [[ ! -f "$creds_file" ]] && error_exit "credentials file not found: $creds_file"

    local access_token refresh_token expires_at subscription_type
    access_token="$(jq -r '.claudeAiOauth.accessToken' "$creds_file")"
    refresh_token="$(jq -r '.claudeAiOauth.refreshToken' "$creds_file")"
    expires_at="$(jq -r '.claudeAiOauth.expiresAt' "$creds_file")"
    subscription_type="$(jq -r '.claudeAiOauth.subscriptionType' "$creds_file")"

    local tmpfile
    tmpfile="$(mktemp)"

    # Strip existing CLAUDE_ credential lines; preserve all other vars
    if [[ -f "$env_file" ]]; then
        grep -v -E "^CLAUDE_(ACCESS_TOKEN|REFRESH_TOKEN|TOKEN_EXPIRES_AT|SUBSCRIPTION_TYPE)=" \
            "$env_file" > "$tmpfile" || true
    fi

    # Append updated credentials
    printf 'CLAUDE_ACCESS_TOKEN=%s\n'      "$access_token"      >> "$tmpfile"
    printf 'CLAUDE_REFRESH_TOKEN=%s\n'     "$refresh_token"     >> "$tmpfile"
    printf 'CLAUDE_TOKEN_EXPIRES_AT=%s\n'  "$expires_at"        >> "$tmpfile"
    printf 'CLAUDE_SUBSCRIPTION_TYPE=%s\n' "$subscription_type" >> "$tmpfile"

    mv "$tmpfile" "$env_file"
    echo "Imported Claude credentials to $env_file"
}

cmd_stop() {
    local target="${1:-}"
    [[ -z "$target" ]] && error_exit "worker-id or --all is required"

    if [[ "$target" == "--all" ]]; then
        "$RUNTIME" stop-all
    else
        "$RUNTIME" stop "$target"
    fi
}

[[ $# -eq 0 ]] && usage

case "$1" in
    status)
        shift
        cmd_status
        ;;
    workers)
        shift
        cmd_workers "$@"
        ;;
    planners)
        shift
        cmd_planners "$@"
        ;;
    add)
        shift
        cmd_add "$@"
        ;;
    logs)
        shift
        cmd_logs "$@"
        ;;
    stop)
        shift
        cmd_stop "$@"
        ;;
    import-claude-credentials)
        shift
        cmd_import_claude_credentials "$@"
        ;;
    --help|-h)
        usage
        ;;
    *)
        error_exit "Unknown command: $1"
        ;;
esac
