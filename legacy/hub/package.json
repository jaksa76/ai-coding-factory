{
  "name": "ai-coding-factory-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI Coding Factory Hub (Express + zx)",
  "scripts": {
    "start": "node --env-file=.env src/server.mjs",
    "dev": "DATA_DIR=demo-data node --watch src/server.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node --env-file=.env node_modules/.bin/playwright test"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-validator": "^7.3.1",
    "fs-extra": "^11.2.0",
    "morgan": "^1.10.0",
    "zx": "^8.1.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "supertest": "^7.0.0",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18"
  }
}
