#!/usr/bin/env bash
set -euo pipefail

# loop — agent-agnostic claim/work loop
#
# Usage:
#   loop --project <key> [--for-planning]
#
# Environment variables:
#   JIRA_SITE                 — Jira host, e.g. mycompany.atlassian.net
#   JIRA_EMAIL                — Jira account email
#   JIRA_TOKEN                — Jira API token
#   JIRA_ASSIGNEE_ACCOUNT_ID  — Jira account ID used for self-assignment
#   GIT_REPO_URL              — Repository to work on
#   GIT_USERNAME              — Git push credentials
#   GIT_TOKEN                 — Git push credentials
#   PLAN_BY_DEFAULT           — Optional, see docs/planning-phase.md (used by claim)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$PATH:$SCRIPT_DIR"

usage() {
    echo "Usage: loop --project <key> [--for-planning]"
    echo ""
    echo "Environment variables required (jira backend, default):"
    echo "  JIRA_SITE                 Jira host (e.g. mycompany.atlassian.net)"
    echo "  JIRA_EMAIL                Jira account email"
    echo "  JIRA_TOKEN                Jira API token"
    echo "  JIRA_ASSIGNEE_ACCOUNT_ID  Jira account ID for self-assignment"
    echo ""
    echo "Environment variables required (github backend):"
    echo "  GH_TOKEN                  GitHub personal access token"
    echo "  GITHUB_ASSIGNEE           GitHub username for self-assignment"
    echo ""
    echo "Environment variables required (all backends):"
    echo "  GIT_REPO_URL              Repository URL to work on"
    echo "  GIT_USERNAME              Git push credentials"
    echo "  GIT_TOKEN                 Git push credentials"
    echo ""
    echo "Optional environment variables:"
    echo "  TASK_MANAGER              Backend to use: jira (default) or github"
    echo "  NO_ISSUES_WAIT            Seconds to wait when no issues are available (default: 60)"
    echo "  INTER_ISSUE_WAIT          Seconds to wait between issues (default: 1200; 300 in planning mode)"
    echo ""
    echo "Flags:"
    echo "  --for-planning            Run in planning mode (claim and plan issues)"
    exit 1
}

error_exit() {
    echo "Error: $1" >&2
    exit 1
}

# Parse arguments
PROJECT=""
FOR_PLANNING=false
while [[ $# -gt 0 ]]; do
    case "$1" in
        --project)
            PROJECT="$2"; shift 2;;
        --for-planning)
            FOR_PLANNING=true; shift;;
        --help|-h)
            usage;;
        *)
            error_exit "Unknown option: $1";;
    esac
done

[[ -z "$PROJECT" ]] && error_exit "--project <key> is required"

if [[ "${TASK_MANAGER:-jira}" == "github" ]]; then
    [[ -z "${GH_TOKEN:-}" ]]        && error_exit "GH_TOKEN is not set"
    [[ -z "${GITHUB_ASSIGNEE:-}" ]] && error_exit "GITHUB_ASSIGNEE is not set"
    ASSIGNEE_ID="$GITHUB_ASSIGNEE"
    export GITHUB_REPO="$PROJECT"
elif [[ "${TASK_MANAGER:-jira}" == "todo" ]]; then
    [[ -z "${TODO_ASSIGNEE:-}" ]] && error_exit "TODO_ASSIGNEE is not set"
    ASSIGNEE_ID="$TODO_ASSIGNEE"
    export TODO_FILE="$PROJECT"
else
    [[ -z "${JIRA_SITE:-}" ]]                && error_exit "JIRA_SITE environment variable is not set"
    [[ -z "${JIRA_EMAIL:-}" ]]               && error_exit "JIRA_EMAIL environment variable is not set"
    [[ -z "${JIRA_TOKEN:-}" ]]               && error_exit "JIRA_TOKEN environment variable is not set"
    [[ -z "${JIRA_ASSIGNEE_ACCOUNT_ID:-}" ]] && error_exit "JIRA_ASSIGNEE_ACCOUNT_ID environment variable is not set"
    ASSIGNEE_ID="$JIRA_ASSIGNEE_ACCOUNT_ID"
fi
[[ -z "${GIT_REPO_URL:-}" ]]  && error_exit "GIT_REPO_URL environment variable is not set"
[[ -z "${GIT_USERNAME:-}" ]]  && error_exit "GIT_USERNAME environment variable is not set"
[[ -z "${GIT_TOKEN:-}" ]]     && error_exit "GIT_TOKEN environment variable is not set"

# Extract the JSON block (lines from first '{' onward) from claim output.
parse_claim_output() {
    local output="$1"
    printf '%s\n' "$output" | awk '/^\{/{f=1} f'
}

# Claim an issue, setting ISSUE_KEY.
# Pass --for-planning to claim a planning issue.
# Returns 0 on success; sleeps and returns 1 when no issues are available;
# exits with the claim exit code on other errors.
claim_issue() {
    local extra_args=()
    [[ "${1:-}" == "--for-planning" ]] && extra_args=("--for-planning")

    echo "Claiming issue from project $PROJECT..."
    local claim_output claim_exit
    set +e
    claim_output="$(task-manager claim --project "$PROJECT" --account-id "$ASSIGNEE_ID" "${extra_args[@]}")"
    claim_exit=$?
    set -e
    echo "$claim_output"

    if [[ "$claim_exit" -eq 2 ]]; then
        local no_issues_wait="${NO_ISSUES_WAIT:-60}"
        if [[ "${1:-}" == "--for-planning" ]]; then
            echo "No planning issues available in project $PROJECT. Waiting ${no_issues_wait}s..."
        else
            echo "No issues available in project $PROJECT. Waiting ${no_issues_wait}s before polling again..."
        fi
        sleep "$no_issues_wait"
        return 1
    elif [[ "$claim_exit" -ne 0 ]]; then
        exit "$claim_exit"
    fi

    local issue_json
    issue_json="$(parse_claim_output "$claim_output")"
    ISSUE_KEY="$(printf '%s\n' "$issue_json" | jq -r '.key')"
}

run_planning_loop() {
    while true; do
        claim_issue --for-planning || continue
        plan "$ISSUE_KEY"
        sleep "${INTER_ISSUE_WAIT:-300}"
    done
}

run_implementation_loop() {
    while true; do
        claim_issue || continue
        implement "$ISSUE_KEY"
        sleep "${INTER_ISSUE_WAIT:-1200}"
    done
}

if [[ "$FOR_PLANNING" == "true" ]]; then
    run_planning_loop
else
    run_implementation_loop
fi
