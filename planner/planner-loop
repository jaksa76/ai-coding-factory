#!/usr/bin/env bash
set -euo pipefail

# planner-loop — worker for planning phase only
#
# Usage:
#   planner-loop --project <key> --agent <command>
#
# Environment variables:
#   JIRA_SITE                 — Jira host, e.g. mycompany.atlassian.net
#   JIRA_EMAIL                — Jira account email
#   JIRA_TOKEN                — Jira API token
#   JIRA_ASSIGNEE_ACCOUNT_ID  — Jira account ID used for self-assignment
#   GIT_REPO_URL              — Repository to work on
#   GIT_USERNAME              — Git push credentials
#   GIT_TOKEN                 — Git push credentials
#   PLAN_BY_DEFAULT           — Optional, see docs/planning-phase.md (used by claim)

usage() {
    echo "Usage: planner-loop --project <key> --agent <command>"
    echo ""
    echo "Environment variables required:"
    echo "  JIRA_SITE                 Jira host (e.g. mycompany.atlassian.net)"
    echo "  JIRA_EMAIL                Jira account email"
    echo "  JIRA_TOKEN                Jira API token"
    echo "  JIRA_ASSIGNEE_ACCOUNT_ID  Jira account ID for self-assignment"
    echo "  GIT_REPO_URL              Repository URL to work on"
    echo "  GIT_USERNAME              Git push credentials"
    echo "  GIT_TOKEN                 Git push credentials"
    echo ""
    echo "Optional environment variables:"
    echo "  NO_ISSUES_WAIT            Seconds to wait when no issues are available (default: 60)"
    echo "  INTER_ISSUE_WAIT          Seconds to wait between issues (default: 1200)"
    exit 1
}

error_exit() {
    echo "Error: $1" >&2
    exit 1
}

# Parse arguments
PROJECT=""
AGENT_CMD=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --project)
            PROJECT="$2"; shift 2;;
        --agent)
            AGENT_CMD="$2"; shift 2;;
        --help|-h)
            usage;;
        *)
            error_exit "Unknown option: $1";;
    esac
done

[[ -z "$PROJECT" ]]   && error_exit "--project <key> is required"
[[ -z "$AGENT_CMD" ]] && error_exit "--agent <command> is required"

[[ -z "${JIRA_SITE:-}" ]]                && error_exit "JIRA_SITE environment variable is not set"
[[ -z "${JIRA_EMAIL:-}" ]]               && error_exit "JIRA_EMAIL environment variable is not set"
[[ -z "${JIRA_TOKEN:-}" ]]               && error_exit "JIRA_TOKEN environment variable is not set"
[[ -z "${JIRA_ASSIGNEE_ACCOUNT_ID:-}" ]] && error_exit "JIRA_ASSIGNEE_ACCOUNT_ID environment variable is not set"
[[ -z "${GIT_REPO_URL:-}" ]]             && error_exit "GIT_REPO_URL environment variable is not set"
[[ -z "${GIT_USERNAME:-}" ]]             && error_exit "GIT_USERNAME environment variable is not set"
[[ -z "${GIT_TOKEN:-}" ]]                && error_exit "GIT_TOKEN environment variable is not set"

# Set up git credential store for HTTPS authentication (avoids embedding
# credentials in URLs where they could appear in process listings or logs)
if [[ "$GIT_REPO_URL" == https://* ]]; then
    _GIT_CRED_FILE="$(mktemp)"
    chmod 600 "$_GIT_CRED_FILE"
    _GIT_HOST="$(printf '%s\n' "$GIT_REPO_URL" | sed 's|https://||' | cut -d'/' -f1)"
    printf 'https://%s:%s@%s\n' "$GIT_USERNAME" "$GIT_TOKEN" "$_GIT_HOST" > "$_GIT_CRED_FILE"
    git config --global credential.helper "store --file $_GIT_CRED_FILE"
    trap "rm -f '$_GIT_CRED_FILE'" EXIT
fi

# Configure git user identity for commits
git config --global user.name "$GIT_USERNAME"
git config --global user.email "$JIRA_EMAIL"

# Derive local repo directory name from URL
REPO_NAME="$(basename "$GIT_REPO_URL" .git)"
# LOOP_WORK_DIR allows tests to override the base directory; defaults to cwd
BASE_DIR="${LOOP_WORK_DIR:-$(pwd)}"
WORK_DIR="$BASE_DIR/$REPO_NAME"

# Run the agent, retrying on rate-limit errors.
# Usage: run_agent_with_retry <prompt> <issue_key>
run_agent_with_retry() {
    local prompt="$1" issue_key="$2"
    local default_wait=60

    while true; do
        local tmpout agent_exit=0
        tmpout="$(mktemp)"

        # Run agent; stream output to stdout and capture to file for analysis
        set +e
        (cd "$WORK_DIR" && $AGENT_CMD "$prompt") 2>&1 | tee "$tmpout"
        agent_exit="${PIPESTATUS[0]}"
        set -e

        if [[ "$agent_exit" -eq 0 ]]; then
            rm -f "$tmpout"
            return 0
        fi

        # Check for rate-limit indicators in captured output
        if grep -qi "rate.limit\|too many requests\|429\|overloaded" "$tmpout"; then
            # Try to parse a retry-after duration from the output
            local wait_secs="$default_wait"
            local parsed
            parsed="$(grep -oiE "retry.?after:? ?[0-9]+" "$tmpout" | grep -oE "[0-9]+" | tail -1 || true)"
            [[ -n "$parsed" ]] && wait_secs="$parsed"

            echo "Agent hit rate limit for $issue_key. Waiting ${wait_secs}s before retry..."
            rm -f "$tmpout"
            sleep "$wait_secs"
        else
            rm -f "$tmpout"
            return "$agent_exit"
        fi
    done
}

while true; do
    # Step 1: Claim a Jira issue
    echo "Claiming issue from project $PROJECT..."
    set +e
    CLAIM_OUTPUT="$(claim --project "$PROJECT" --account-id "$JIRA_ASSIGNEE_ACCOUNT_ID" --for-planning)"
    CLAIM_EXIT=$?
    set -e
    echo "$CLAIM_OUTPUT"

    if [[ "$CLAIM_EXIT" -eq 2 ]]; then
        no_issues_wait="${NO_ISSUES_WAIT:-60}"
        echo "No issues available in project $PROJECT. Waiting ${no_issues_wait}s before polling again..."
        sleep "$no_issues_wait"
        continue
    elif [[ "$CLAIM_EXIT" -ne 0 ]]; then
        exit "$CLAIM_EXIT"
    fi

    # Extract the JSON block (lines from first '{' onward)
    ISSUE_JSON="$(printf '%s\n' "$CLAIM_OUTPUT" | awk '/^\{/{f=1} f')"
    ISSUE_KEY="$(printf '%s\n' "$ISSUE_JSON" | jq -r '.key')"
    ISSUE_SUMMARY="$(printf '%s\n' "$ISSUE_JSON" | jq -r '.summary')"
    # Fetch description separately (claim only outputs key and summary)
    ISSUE_DESCRIPTION="$(acli jira workitem view "$ISSUE_KEY" --json 2>/dev/null \
        | jq -r '.fields.description // ""' 2>/dev/null || true)"

    echo "Working on $ISSUE_KEY: $ISSUE_SUMMARY"

    # Step 2: Clone or pull the repository
    if [[ -d "$WORK_DIR/.git" ]]; then
        echo "Pulling latest changes for $REPO_NAME..."
        git -C "$WORK_DIR" remote set-url origin "$GIT_REPO_URL"
        git -C "$WORK_DIR" pull
    else
        echo "Cloning $GIT_REPO_URL..."
        git clone "$GIT_REPO_URL" "$WORK_DIR"
    fi

    # Step 3: Invoke the agent with the issue as prompt
    PROMPT="Create a plan for the issue described below and save it in plans/$ISSUE_KEY.md\n\n"
    PROMPT="$PROMPT [$ISSUE_KEY] $ISSUE_SUMMARY"
    [[ -n "$ISSUE_DESCRIPTION" ]] && PROMPT="$PROMPT
$ISSUE_DESCRIPTION"

    echo "Running agent for $ISSUE_KEY..."
    echo "=== AGENT START: $ISSUE_KEY ==="
    run_agent_with_retry "$PROMPT" "$ISSUE_KEY"
    echo "=== AGENT END: $ISSUE_KEY ==="


    # Step 4: Commit and push changes
    echo "Committing and pushing changes for $ISSUE_KEY..."
    git -C "$WORK_DIR" add "plans/$ISSUE_KEY.md"
    git -C "$WORK_DIR" commit -m "Add plan for $ISSUE_KEY"
    git -C "$WORK_DIR" push "$GIT_REPO_URL" HEAD

    # Step 5: Comment on Jira
    PLAN_URL="https://github.com/$GIT_USERNAME/$REPO_NAME/blob/main/plans/$ISSUE_KEY.md"
    echo "Plan URL: $PLAN_URL"
    echo "Posting comment on $ISSUE_KEY..."
    set +e
    # plan url in github UI
    acli jira workitem comment create --key "$ISSUE_KEY" \
        --body "Created plan: $PLAN_URL" 2>/dev/null
    COMMENT_EXIT=$?
    set -e
    if [[ "$COMMENT_EXIT" -ne 0 ]]; then
        echo "Warning: could not post comment on $ISSUE_KEY"                
    fi

    # Step 6: Transition to Awaiting Plan Review
    echo "Transitioning $ISSUE_KEY to Awaiting Plan Review..."
    set +e
    acli jira workitem transition --key "$ISSUE_KEY" \
        --status "Awaiting Plan Review" --yes 2>/dev/null
    TRANSITION_EXIT=$?
    set -e
    if [[ "$TRANSITION_EXIT" -ne 0 ]]; then
        echo "Warning: could not transition $ISSUE_KEY to Awaiting Plan Review"
    fi

    echo "Finished planning $ISSUE_KEY."

    inter_issue_wait="${INTER_ISSUE_WAIT:-300}"
    sleep "$inter_issue_wait" # Sleep before claiming the next issue
done
