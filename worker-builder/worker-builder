#!/usr/bin/env bash
set -euo pipefail

# worker-builder — generate a project-specific worker Docker image
#
# Usage:
#   worker-builder build --devcontainer <workspace-folder> --type <claude|copilot|codex> [--tag <tag>] [--push]
#
# Runs devcontainer build to build the project's devcontainer image, then layers
# the chosen agent CLI + loop + task-manager on top of it.

# Resolve the ai-coding-factory repo root (two levels up from this script)
TOOL_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$TOOL_DIR/.." && pwd)"

usage() {
    echo "Usage: worker-builder build --devcontainer <workspace-folder> --type <agent> [--tag <tag>] [--push]"
    echo ""
    echo "Subcommands:"
    echo "  build   Build a worker image from a devcontainer workspace"
    echo ""
    echo "Options:"
    echo "  --devcontainer <workspace-folder>  Workspace folder containing .devcontainer/"
    echo "  --type <type>                      Agent type: claude, copilot, or codex"
    echo "  --tag <tag>                        Docker image tag (default: worker-<type>:latest)"
    echo "  --push                             Push the image after building"
    exit 1
}

error_exit() {
    echo "Error: $1" >&2
    exit 1
}

# ── subcommand dispatch ───────────────────────────────────────────────────────

SUBCOMMAND=""
if [[ $# -gt 0 && "$1" != --* && "$1" != -* ]]; then
    SUBCOMMAND="$1"
    shift
fi

case "$SUBCOMMAND" in
    build) ;;
    "")
        # No subcommand — show usage
        usage
        ;;
    --help|-h)
        usage
        ;;
    *)
        error_exit "Unknown subcommand: $SUBCOMMAND"
        ;;
esac

# ── argument parsing (build subcommand) ──────────────────────────────────────

DEVCONTAINER_ARG=""
AGENT=""
TAG=""
PUSH=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --devcontainer)
            [[ -z "${2:-}" || "${2:-}" == --* ]] && error_exit "--devcontainer requires a value"
            DEVCONTAINER_ARG="$2"; shift 2
            ;;
        --type)
            [[ -z "${2:-}" || "${2:-}" == --* ]] && error_exit "--type requires a value"
            AGENT="$2"; shift 2
            ;;
        --tag)
            [[ -z "${2:-}" || "${2:-}" == --* ]] && error_exit "--tag requires a value"
            TAG="$2"; shift 2
            ;;
        --push)
            PUSH=true; shift
            ;;
        --help|-h)
            usage
            ;;
        *)
            error_exit "Unknown option: $1"
            ;;
    esac
done

[[ -z "$DEVCONTAINER_ARG" ]] && error_exit "--devcontainer <workspace-folder> is required"
[[ -z "$AGENT" ]]            && error_exit "--type <agent> is required"

case "$AGENT" in
    claude|copilot|codex) ;;
    *) error_exit "Unknown agent type '$AGENT' (must be claude, copilot, or codex)" ;;
esac

[[ -z "$TAG" ]] && TAG="worker-${AGENT}:latest"

echo "Building worker image"
echo "Devcontainer: $DEVCONTAINER_ARG"
echo "Agent: $AGENT"
echo "Tag:   $TAG"

# ── ensure devcontainer CLI is available ──────────────────────────────────────

if ! command -v devcontainer >/dev/null 2>&1; then
    echo "devcontainer CLI not found — installing via npm..."
    npm install -g @devcontainers/cli
fi

# ── build devcontainer base image ─────────────────────────────────────────────

WORK_DIR="$(mktemp -d)"
trap 'rm -rf "$WORK_DIR"' EXIT

BASE_TAG="worker-base-${AGENT}:latest"
devcontainer build \
    --workspace-folder "$DEVCONTAINER_ARG" \
    --image-name "$BASE_TAG"
BASE_IMAGE="$BASE_TAG"

# ── generate Dockerfile ───────────────────────────────────────────────────────

DOCKERFILE="$WORK_DIR/Dockerfile"

{
    printf 'FROM %s\n' "$BASE_IMAGE"
    printf '\n'
    printf '# Install system dependencies\n'
    printf 'RUN apt-get update && apt-get install -y \\\n'
    printf '    bash curl git jq wget gnupg2 \\\n'
    printf '    && rm -rf /var/lib/apt/lists/*\n'
    printf '\n'
    printf '# Install acli (Atlassian CLI) for Jira operations\n'
    printf 'RUN mkdir -p -m 755 /etc/apt/keyrings \\\n'
    printf '    && wget -nv -O- https://acli.atlassian.com/gpg/public-key.asc \\\n'
    printf '        | gpg --dearmor -o /etc/apt/keyrings/acli-archive-keyring.gpg \\\n'
    printf '    && chmod go+r /etc/apt/keyrings/acli-archive-keyring.gpg \\\n'
    printf '    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/acli-archive-keyring.gpg] https://acli.atlassian.com/linux/deb stable main" \\\n'
    printf '        | tee /etc/apt/sources.list.d/acli.list > /dev/null \\\n'
    printf '    && apt-get update \\\n'
    printf '    && apt-get install -y acli \\\n'
    printf '    && rm -rf /var/lib/apt/lists/*\n'
    printf '\n'

    case "$AGENT" in
        claude)
            printf '# Install Claude Code CLI\n'
            printf 'RUN curl -fsSL https://claude.ai/install.sh | bash\n'
            printf 'ENV PATH="/root/.local/bin:$PATH"\n'
            ;;
        copilot)
            printf '# Install gh CLI\n'
            printf 'RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \\\n'
            printf '        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \\\n'
            printf '    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \\\n'
            printf '    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \\\n'
            printf '        | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \\\n'
            printf '    && apt-get update \\\n'
            printf '    && apt-get install -y gh \\\n'
            printf '    && rm -rf /var/lib/apt/lists/*\n'
            printf '\n'
            printf '# Install @github/copilot CLI\n'
            printf 'RUN npm install -g @github/copilot && \\\n'
            printf '    printf '"'"'#!/bin/sh\\nexec node /usr/local/lib/node_modules/@github/copilot/index.js "$$@"\\n'"'"' > /usr/local/bin/copilot && \\\n'
            printf '    chmod +x /usr/local/bin/copilot\n'
            ;;
        codex)
            printf '# Install OpenAI Codex CLI\n'
            printf 'RUN npm install -g @openai/codex\n'
            ;;
    esac

    printf '\n'
    printf '# Install loop, task-manager, and agent tools\n'
    printf '# Build context: repository root (docker build -f <dockerfile> <repo-root>)\n'
    printf 'COPY loop/loop /usr/local/bin/loop\n'
    printf 'COPY loop/implement /usr/local/bin/implement\n'
    printf 'COPY loop/git-utils.sh /usr/local/bin/git-utils.sh\n'
    printf 'COPY task-manager/task-manager /usr/local/bin/task-manager\n'
    printf 'COPY workers/%s/agent /usr/local/bin/agent\n' "$AGENT"
    printf 'RUN chmod +x /usr/local/bin/loop /usr/local/bin/implement /usr/local/bin/task-manager /usr/local/bin/agent\n'
    printf '\n'
    printf 'ENTRYPOINT ["bash", "-c", "loop --project \"$JIRA_PROJECT\""]\n'
} > "$DOCKERFILE"

echo "Generated Dockerfile:"
cat "$DOCKERFILE"

# ── build the image ───────────────────────────────────────────────────────────

echo "Building Docker image $TAG..."
docker build -t "$TAG" -f "$DOCKERFILE" "$REPO_ROOT"

# ── optionally push ───────────────────────────────────────────────────────────

if [[ "$PUSH" == "true" ]]; then
    echo "Pushing image $TAG..."
    docker push "$TAG"
fi

echo "Done. Image: $TAG"
