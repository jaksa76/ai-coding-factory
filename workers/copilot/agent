#!/usr/bin/env bash
# agent — wrapper for GitHub Copilot CLI
#
# Usage:
#   agent init          — initialise Copilot authentication (idempotent)
#   agent run <prompt>  — run the agent in batch mode with all permissions

set -euo pipefail

usage() {
    echo "Usage: agent <command> [args]"
    echo ""
    echo "Commands:"
    echo "  init          Initialise Copilot authentication"
    echo "  run <prompt>  Execute prompt in batch mode with all permissions"
    exit 1
}

cmd="${1:-}"

case "$cmd" in
    init)
        if [[ -z "${GH_TOKEN:-}" ]]; then
            echo "ERROR: GH_TOKEN is required for GitHub Copilot CLI authentication" >&2
            exit 1
        fi
        if [[ -z "${GH_USERNAME:-}" ]]; then
            echo "ERROR: GH_USERNAME is required for GitHub Copilot CLI authentication" >&2
            exit 1
        fi

        if ! command -v copilot &>/dev/null; then
            echo "copilot not found — installing @github/copilot via npm..."
            npm install -g @github/copilot
            bin_dir="${COPILOT_BIN_DIR:-/usr/local/bin}"
            printf '#!/bin/sh\nexec node /usr/local/lib/node_modules/@github/copilot/index.js "$@"\n' \
                > "$bin_dir/copilot"
            chmod +x "$bin_dir/copilot"
        fi

        sed -i "s|\${GH_USERNAME}|${GH_USERNAME}|g; s|\${GH_TOKEN}|${GH_TOKEN}|g" \
            /root/.copilot/config.json

        echo "Copilot authentication initialized for ${GH_USERNAME}"
        ;;

    run)
        prompt="${2:-}"
        model_args=()
        if [[ -n "${COPILOT_MODEL:-}" ]]; then
            model_args=(--model "$COPILOT_MODEL")
        fi
        exec copilot --allow-all --no-ask-user "${model_args[@]}" -p "$prompt"
        ;;

    *)
        usage
        ;;
esac
